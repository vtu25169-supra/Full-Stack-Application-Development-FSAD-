<?php
$conn = new mysqli("localhost", "root", "", "student_db");

$order = $_GET['sort'] ?? 'name';
$dept_filter = $_GET['dept'] ?? '';

$sql = "SELECT * FROM students";

if ($dept_filter != '') {
    $sql .= " WHERE department='$dept_filter'";
}

$sql .= " ORDER BY $order";

$result = $conn->query($sql);
?>

