DELIMITER $$

CREATE TRIGGER after_transaction_insert
AFTER INSERT ON Transactions
FOR EACH ROW
BEGIN
    INSERT INTO Transaction_Log (
        transaction_id,
        action_type,
        description
    )
    VALUES (
        NEW.transaction_id,
        'INSERT',
        CONCAT('Inserted transaction of amount ', NEW.amount, ' for ', NEW.account_name)
    );
END $$

DELIMITER ;
